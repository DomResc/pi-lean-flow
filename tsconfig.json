{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
  },
  "include": ["extension.ts", "state/**/*.ts", "quality/**/*.ts", "util/**/*.ts"],
  "exclude": ["dist", "node_modules", ".pi-lean-flow", "**/*.test.ts", "vitest.config.ts"],
}
